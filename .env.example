# ============================================
# Demiurge Lead Matcher - Environment Variables
# ============================================

# Database (Supabase or Local Postgres)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
DATABASE_URL=postgresql://demiurge:demiurge_secret@localhost:5432/demiurge

# Redis (for job queues)
REDIS_URL=redis://localhost:6379

# Next.js App
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Worker Configuration
CRAWLER_ENABLED=true
CRAWLER_MAX_CONCURRENT_JOBS=3
CRAWLER_REQUEST_DELAY_MS=1000

# Intent Detection
INTENT_MIN_CONFIDENCE=0.6
LEAD_AUTO_APPROVE_SCORE=85
MATCHING_MIN_SCORE=50

# Compliance
OUTREACH_REQUIRE_APPROVAL=true
DATA_RETENTION_DAYS=90

# Optional: LLM for enhanced intent detection
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# Optional: Email/SMS providers for outreach
SENDGRID_API_KEY=SG.xxx
TWILIO_ACCOUNT_SID=AC.xxx
TWILIO_AUTH_TOKEN=xxx
